  var current_section = 1;
  $(window).mousewheel(function (event, delta) {
    
      event.stopPropagation();
      $(".right-side").css('bottom',$(window).scrollTop()*-1);
      if (delta > 0 && current_section > 1) {
          current_section--; //up
          $('body, html').stop().animate({
              scrollTop: $('div[name="section' + current_section + '"]').offset().top
          }, 'slow');
      } else if (delta < 0  && current_section < 7) {
          current_section++; //down
          $('body, html').stop().animate({
              scrollTop: $('div[name="section' + current_section + '"]').offset().top
          }, 'slow');
      }
      console.log(delta);
      return false;
  });


</script>
